PORT=3000

# Postgres (IMPORTANTE: host = nombre del servicio "postgres" en docker-compose)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=notifications_db
DB_USER=notifications_user
DB_PASSWORD=your_db_password_here

DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONN_TIMEOUT_MS=2000

# Redis
REDIS_URL=redis://user:password@host:port
REDIS_NOTIF_CHANNEL=notifications-service/eventos
